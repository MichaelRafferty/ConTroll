[report]
	name="artShowMailInUsage"
	auth=art_control
	csvfile="artShowMailInUsage"
[F010]
    name=exhibitorId
    title="Ex#"
    sql=e.id
    sort=true
    filter=true
    align=right
[F011]
    name=artistNum
    title="Art#"
    sql=eRY.exhibitorNumber
    sort=true
    filter=true
    align=right
[F015]
    name=artistName
    sql="IFNULL(e.artistName, e.exhibitorName)"
    title="Artist Name"
    minWidth=200
    sort=true
    filter=true
[F017]
    name=email
    sql=e.exhibitorEmail
    title="Email"
    minWidth=200
[F019]
    name=Phone
    sql=e.exhibitorPhone
    title="Artist Phone"
    sort=false
    filter=false
[F020]
    name=reqUnits
    title="#Req"
    sql=r.units
    sort=false
    align=right
[F021]
    name=reqItems
    title="Requested"
    sql=r.items
    sort=false
[F022]
    name=appUnits
    title="#App"
    sql=a.units
    sort=false
    align=right
[F023]
    name=appItems
    title="Approved"
    sql=a.items
    sort=false
[F024]
    name=purUnits
    title="#Pur"
    sql=p.units
    sort=false
    align=right
[F025]
    name=purItems
    title="Purchased"
    sql=p.items
    sort=false
[F026]
    name=items
    sql=i.items
    title="Items"
    align=right
    sort=false
[C001]
    name=items
    select="SELECT eRY.id as eRY, COUNT(*) AS items"
    tables="FROM artItems I JOIN exhibitorRegionYears eRY ON eRY.id=I.exhibitorRegionYearId"
    where="WHERE I.conid = ? GROUP BY eRY.id"
[C002]
    name=requested
    select="SELECT eRY.id, MIN(time_requested) AS requested, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
    tables="FROM exhibitorSpaces s JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id LEFT OUTER JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id"
    where="WHERE eY.conid = ? AND s.time_requested IS NOT NULL GROUP BY eRY.id"
[C003]
     name=purchased
     select="SELECT eRY.id, MIN(time_purchased) AS purchased, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
     tables="FROM exhibitorSpaces s JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id LEFT OUTER JOIN exhibitsSpacePrices xsp ON s.item_purchased = xsp.id"
     where="WHERE eY.conid = ? AND s.time_purchased IS NOT NULL GROUP BY eRY.id"
[C004]
     name=approved
     select="SELECT eRY.id, MIN(time_approved) AS approved, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
     tables="FROM exhibitorSpaces s JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id LEFT OUTER JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id"
     where="WHERE eY.conid = ? AND s.time_approved IS NOT NULL GROUP BY eRY.id"
[T001]
    name=exhibitorRegionYears
    alias=eRY
[T002]
	name=exhibitorYears
	alias=eY
	join="eRY.exhibitorYearId=eY.id"
[T003]
	name=exhibitors
	alias=e
	join="e.id=eY.exhibitorId"
[T020]
    name=exhibitsRegionYears
    alias=xRY
    join="xRY.id = eRY.exhibitsRegionYearId"
[T021]
    name=exhibitsRegions
    alias=xR
    join="xR.id=xRY.exhibitsRegion"
[T022]
    name=exhibitsRegionTypes
    alias=xRT
    join="xR.regionType=xRT.regionType"
[T030]
    name=items
    alias=i
    join="eRY.id = i.eRY"
    left=true
[T031]
    name=requested
    alias=r
    join="eRY.id = r.id"
    left=true
[T032]
    name=purchased
    alias=p
    join="eRY.id = p.id"
    left=true
[T033]
    name=approved
    alias=a
    join="eRY.id = a.id"
    left=true
[P001]
    type=prompt
    item=conid
    datatype=i
[P002]
    type=prompt
    item=conid
    datatype=i
[P003]
    type=prompt
    item=conid
    datatype=i
[P004]
    type=prompt
    item=conid
    datatype=i
[P005]
    type=prompt
    item=conid
    datatype=i
[P006]
    type=prompt
    item=region
    datatype=s
[where]
	001="eY.conid = ? AND LOWER(xR.shortname) LIKE LOWER(?) AND eY.mailin = 'Y' AND (IFNULL(r.units, 0) > 0 OR IFNULL(e.artistName, '') != '')"
[sort]
	001="eRY.exhibitorNumber"
