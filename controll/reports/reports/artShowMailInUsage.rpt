[F026]
    name=items
    sql=i.items
    title="# Items"
    align=right
    sort=false
[C001]
    name=items
    select="SELECT eRY.id as eRY, COUNT(*) AS items"
    tables="FROM artItems I
    JOIN exhibitorRegionYears eRY ON eRY.id=I.exhibitorRegionYearId
    JOIN exhibitsRegionYears xry ON eRY.exhibitsRegionYearId
    JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
    "
    where="WHERE I.conid = ? AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id"
[C002]
    name=requested
    select="SELECT eRY.id, MIN(time_requested) AS requested, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
    tables="FROM exhibitorSpaces s
    JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
    JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
    JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id
    JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
    JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
    JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
    "
    where="WHERE eY.conid = ? AND s.time_requested IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id"
[C003]
     name=purchased
     select="SELECT eRY.id, MIN(time_purchased) AS purchased, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
     tables="FROM exhibitorSpaces s
     JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
     JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
     JOIN exhibitsSpacePrices xsp ON s.item_purchased = xsp.id
     JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
     JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
     JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
     "
     where="WHERE eY.conid = ? AND s.time_purchased IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id"
[C004]
     name=approved
     select="SELECT eRY.id, MIN(time_approved) AS approved, SUM(xsp.units) AS units, GROUP_CONCAT(xsp.description SEPARATOR ',\n') AS items"
     tables="FROM exhibitorSpaces s
     JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
     JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
     JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id
     JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
     JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
     JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
     "
     where="WHERE eY.conid = ? AND s.time_approved IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id"
[T001]
    name=exhibitorRegionYears
    alias=eRY
[T002]
	name=exhibitorYears
	alias=eY
	join="eRY.exhibitorYearId=eY.id"
[T003]
	name=exhibitors
	alias=e
	join="e.id=eY.exhibitorId"
[T020]
    name=exhibitsRegionYears
    alias=xRY
    join="xRY.id = eRY.exhibitsRegionYearId"
[T021]
    name=exhibitsRegions
    alias=xR
    join="xR.id=xRY.exhibitsRegion"
[T022]
    name=exhibitsRegionTypes
    alias=xRT
    join="xR.regionType=xRT.regionType"
[T030]
    name=items
    alias=i
    join="eRY.id = i.eRY"
    left=true
[T031]
    name=requested
    alias=r
    join="eRY.id = r.id"
    left=true
[T032]
    name=purchased
    alias=p
    join="eRY.id = p.id"
    left=true
[T033]
    name=approved
    alias=a
    join="eRY.id = a.id"
    left=true
