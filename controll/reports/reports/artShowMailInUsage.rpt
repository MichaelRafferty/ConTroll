[report]
	name="artShowMailInUsage"
	auth=art_control
	csvfile="artShowMailInUsage"
	totals="bottom"
	subtotals="reqSpace"
[F010]
    name=exhibitorId
    title="Ex#"
    sql=e.id
    sort=true
    filter=true
    align=right
[F011]
    name=artistNum
    title="Art#"
    sql=eRY.exhibitorNumber
    sort=true
    filter=true
    align=right
[F015]
    name=artistName
    sql="IFNULL(e.artistName, e.exhibitorName)"
    title="Artist Name"
    minWidth=200
    sort=false
    filter=true
[F020]
    name=reqUnits
    title="Req Units"
    sql=r.units
    sort=false
    align=right
    wdith=100
    calc="sum"
[F021]
    name=reqSpace
    title="Requested Space"
    sql=r.space
    width=150
    sort=true
[F022]
    name=appUnits
    title="App/Pur Units"
    sql="IFNULL(p.units, a.units)"
    sort=false
    align=right
    width=100
    calc="sum"
[F023]
    name=appSpace
    title="App/Pur Space"
    sql="IFNULL(p.space, a.space)"
    width=150
    sort=false
[F026]
    name=status
    title="Status"
    sql="CASE WHEN purchased IS NOT NULL THEN 'Purchased' WHEN approved IS NOT NULL THEN 'Approved' WHEN requested IS NOT NULL THEN 'Requested' ELSE '' END"
    sort=false
[F028]
    name=items
    sql="IFNULL(i.items,0)"
    title="# Items"
    align=right
    sort=false
    width=80
    calc="sum"
[F030]
    name="Date"
    sql="IFNULL(purchased, IFNULL(approved, requested))"
    title=date
    sort=false
[C001]
    name=items
    select="SELECT eRY.id as eRY, COUNT(*) AS items"
    tables="FROM artItems I
    JOIN exhibitorRegionYears eRY ON eRY.id=I.exhibitorRegionYearId
    JOIN exhibitsRegionYears xry ON eRY.exhibitsRegionYearId
    JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
    "
    where="WHERE I.conid = ? AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id"
[C002]
    name=requested
    select="SELECT eRY.id, MIN(time_requested) AS requested, SUM(xsp.units) AS units, xs.shortname AS space, xs.id AS spaceId"
    tables="FROM exhibitorSpaces s
    JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
    JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
    JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id
    JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
    JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
    JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
    "
    where="WHERE eY.conid = ? AND s.time_requested IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id, xs.shortname, xs.id"
[C003]
     name=purchased
     select="SELECT eRY.id, MIN(time_purchased) AS purchased, SUM(xsp.units) AS units, xs.shortname AS space, xs.id AS spaceId"
     tables="FROM exhibitorSpaces s
     JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
     JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
     JOIN exhibitsSpacePrices xsp ON s.item_purchased = xsp.id
     JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
     JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
     JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
     "
     where="WHERE eY.conid = ? AND s.time_purchased IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id, xs.shortname, xs.id"
[C004]
     name=approved
     select="SELECT eRY.id, MIN(time_approved) AS approved, SUM(xsp.units) AS units, xs.shortname AS space, xs.id AS spaceId"
     tables="FROM exhibitorSpaces s
     JOIN exhibitorRegionYears eRY ON eRY.id = s.exhibitorRegionYear
     JOIN exhibitorYears eY ON eRY.exhibitorYearId = eY.id
     JOIN exhibitsSpacePrices xsp ON s.item_requested = xsp.id
     JOIN exhibitsSpaces xs ON xs.id = xsp.spaceId
     JOIN exhibitsRegionYears xry ON xs.exhibitsRegionYear = xry.id
     JOIN exhibitsRegions xr ON xr.id = xry.exhibitsRegion
     "
     where="WHERE eY.conid = ? AND s.time_approved IS NOT NULL AND LOWER(xr.shortname) LIKE LOWER(?) GROUP BY eRY.id, xs.shortname, xs.id"
[T001]
    name=exhibitorRegionYears
    alias=eRY
[T002]
	name=exhibitorYears
	alias=eY
	join="eRY.exhibitorYearId=eY.id"
[T003]
	name=exhibitors
	alias=e
	join="e.id=eY.exhibitorId"
[T020]
    name=exhibitsRegionYears
    alias=xRY
    join="xRY.id = eRY.exhibitsRegionYearId"
[T021]
    name=exhibitsRegions
    alias=xR
    join="xR.id=xRY.exhibitsRegion"
[T022]
    name=exhibitsRegionTypes
    alias=xRT
    join="xR.regionType=xRT.regionType"
[T024]
    name=exhibitsSpaces
    alias=xs
    join="xRY.id=xs.exhibitsRegionYear"
[T030]
    name=items
    alias=i
    join="eRY.id = i.eRY"
    left=true
[T031]
    name=requested
    alias=r
    join="eRY.id = r.id AND xs.id = r.spaceId"
    left=true
[T032]
    name=purchased
    alias=p
    join="eRY.id = p.id AND xs.id = p.spaceId"
    left=true
[T033]
    name=approved
    alias=a
    join="eRY.id = a.id AND xs.id = a.spaceId"
    left=true
[P0101]
    type=prompt
    item=conid
    datatype=i
[P011]
    type=prompt
    item=region
    datatype=s
[P020]
    type=prompt
    item=conid
    datatype=i
[P021]
    type=prompt
    item=region
    datatype=s
[P030]
    type=prompt
    item=conid
    datatype=i
[P031]
    type=prompt
    item=region
    datatype=s
[P040]
    type=prompt
    item=conid
    datatype=i
[P041]
    type=prompt
    item=region
    datatype=s
[P050]
    type=prompt
    item=conid
    datatype=i
[P051]
    type=prompt
    item=region
    datatype=s
[where]
	001="eY.conid = ? AND LOWER(xR.shortname) LIKE LOWER(?) AND eY.mailin = 'Y' AND IFNULL(r.units, 0) > 0"
[sort]
	001="r.space, e.id"
