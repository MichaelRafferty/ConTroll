[report]
	name="artSalesReconcile"
	auth=art_control
	csvfile="artSalesReconcile"
	index=exhibitorNumber
    totals=bottom
    subtotals=artistName
[F001]
    name=artId
	sql=a.id
	title="Art ID#"
	align=right
	width=80
[F005]
    name=artistId
	sql="IFNULL(eRY.exhibitorNumber, e.id)"
	title="Artist Number"
	align=right
	width=80
	filter=true
	sort=true
[F006]
    name=itemNum
    sql=a.item_key
    title="Item #"
    align=right
    width=80
    filter=true
[F008]
    name=artistName
    sql="CASE WHEN IFNULL(e.artistName, '') = '' THEN e.exhibitorName ELSE e.artistName END"
    title="Artist Name"
    width=300
    filter=true
    format=textarea
[F010]
    name=title
    sql=a.title
    title="Title"
    filter=true
    width=300
    format=textarea
[F012]
    name=type
    sql=a.type
    title="Type"
    filter=true
[F013]
    name=itemStatus
    sql=a.status
    title="Item Status"
    filter=true
    width=140
[F014]
    name=salesStatus
    sql=l.status
    title="Sales Status"
    filter=true
    width=140
[F015]
    name=qtyDiff
    sql="CASE WHEN a.quantity <= a.original_qty THEN a.original_qty - a.quantity ELSE NULL END"
    title="Qty Diff"
    align=right
    width=60
    calc=sum
[F020]
    name=numberSold
    sql="l.salesCount"
    title="# Sold"
    align=right
    width=60
    calc=sum
[F022]
    name=itemPrice
    sql="CASE WHEN a.type = 'art' THEN a.final_price ELSE a.sale_price END"
    title="Item Price"
    align=right
    width=120
[F023]
    name=salesPrice
    sql=s.amount
    title="Item Price"
    align=right
    width=120
    format=money
[F025]
    name=purchasedBy
    sql="GROUP_CONCAT(s.perid SEPARATOR ', ')"
    title="Purchased By"
    filter=true
    align=right
    width=100
    format=textarea
[F030]
    name=totalPrice
    sql="CASE WHEN a.type = 'art' THEN a.final_price ELSE a.sale_price END * CASE WHEN a.quantity <= a.original_qty THEN a.original_qty - a.quantity ELSE NULL END"
    title="Total Price"
    align=right
    width=120
    calc=sum
    format=money
[F035]
    name=totalAmt
    sql="l.amount"
    title="Total Amt"
    align=right
    width=120
    calc=sum
    format=money
[F036]
    name=totalPaid
    sql="l.paid"
    title="Total Amt"
    align=right
    width=120
    calc=sum
    format=money
[C002]
    name=sales
    select="SELECT s.artId, SUM(s.amount) AS amount, SUM(s.paid) AS paid, SUM(s.quantity) AS salesCount, MAX(status) AS status"
    tables="FROM artSales s"
    where="GROUP BY s.artId"
[T001]
	name=exhibitors
	alias=e
[T002]
	name=exhibitorYears
	alias=eY
	join="eY.exhibitorId=e.id"
[T003]
    name=exhibitorRegionYears
    alias=eRY
    join=" eRY.exhibitorYearId = eY.id"
[T005]
    name=exhibitsRegionYears
    alias=xRY
    join="xRY.id = eRY.exhibitsRegionYearId"
[T006]
    name=exhibitsRegions
    alias=xR
    join="xR.id=xRY.exhibitsRegion"
[T010]
    name=artItems
    alias=a
    join="eRY.id = a.exhibitorRegionYearId"
[T011]
    name=artSales
    alias=s
    join="a.id = s.artId"
    left=true
[T012]
    name=sales
    alias=l
    join="a.id = l.artId"
    left=true
[P001]
    type=prompt
    item=conid
    datatype=i
[P002]
    type=prompt
    item=region
    datatype=s
[where]
	W001="eY.conid = ? AND LOWER(xR.shortname) LIKE LOWER(?) AND a.type != 'nfs' AND (a.quantity != a.original_qty || s.amount IS NOT NULL)"
[group]
    G001="a.id,artistId,itemNum,e.artistName,e.exhibitorName,title,a.type,a.sale_price,a.final_price,itemPrice,a.quantity, a.original_qty"
    G002="l.status,s.status,l.salesCount,s.amount,s.paid,l.amount,l.paid"
[sort]
	S001="1,2"
