[report]
	name="artUnpickedUp"
	auth=art_control
	csvfile="artUnpickedUp"
	index=artId
[F001]
    name=artId
	sql=a.artId
	title="Art ID#"
	align=right
	width=60
[F005]
    name=artistId
	sql="IFNULL(eRY.exhibitorNumber, e.id)"
	title="Artist Number"
	align=right
	width=80
	filter=true
	sort=true
[F006]
    name=itemNum
    sql=a.itemNum
    title="Item #"
    align=right
    width=80
    filter=true
[F008]
    name=artistName
    sql="CASE WHEN IFNULL(e.artistName, '') = '' THEN e.exhibitorName ELSE e.artistName END"
    title="Artist Name"
    width= 200
    filter=true
    format=textarea
[F010]
    name=title
    sql=a.title
    title="Title"
    filter=true
    width=200
    format=textarea
[F013]
    name=itemStatus
    sql=a.status
    title="Item Status"
    filter=true
    width=200
[F022]
    name=itemPrice
    sql=a.itemPrice
    title="Item Price"
    align=right
    width=120
    format=money
[F025]
    name=purchasedBy
    sql="a.perid"
    title="Purchased By"
    filter=true
    width=140
    align=right,
[F026]
    name=fullName
    sql="TRIM(REGEXP_REPLACE(CONCAT_WS(' ', p.first_name, p.middle_name, p.last_name, p.suffix), ' +', ' '))"
    title="Full Name"
    minWidth=300
[F030]
    name=totalAmt
    sql=a.amount
    title="Total Amt"
    align=right
    width=120
    format=money
[C001]
    name=art
    select="SELECT a.id AS artId, a.item_key AS itemNum, a.title, a.type, a.exhibitorRegionYearId, a.status, a.final_price AS itemPrice,
    s.amount, s.paid, s.perid"
    tables="FROM artItems a LEFT OUTER JOIN artSales s ON s.artId = a.id"
    where="WHERE a.type = 'art'"
[T001]
	name=exhibitors
	alias=e
[T002]
	name=exhibitorYears
	alias=eY
	join="eY.exhibitorId=e.id"
[T003]
    name=exhibitorRegionYears
    alias=eRY
    join=" eRY.exhibitorYearId = eY.id"
[T005]
    name=exhibitsRegionYears
    alias=xRY
    join="xRY.id = eRY.exhibitsRegionYearId"
[T006]
    name=exhibitsRegions
    alias=xR
    join="xR.id=xRY.exhibitsRegion"
[T010]
    name=art
    alias=a
    join="eRY.id = a.exhibitorRegionYearId"
[T015]
    name=perinfo
    alias=p
    join="a.perid = p.id"
    left=true
[P001]
    type=prompt
    item=conid
    datatype=i
[P002]
    type=prompt
    item=region
    datatype=s
[where]
	W001="eY.conid = ? AND LOWER(xR.shortname) LIKE LOWER(?) AND IFNULL(a.status, '') NOT IN ('Purchased/Released', 'Checked Out', 'Not In Show')"
[sort]
	S001="fullName, a.perid"
