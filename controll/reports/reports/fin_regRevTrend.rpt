[T001]
	name=allrows
	alias=a
[C001]
    name=data
    select="SELECT label, r.conid, count(*) as Count, ROUND(AVG(paid), 2) AS Average, ROUND(SUM(paid),2) AS Revenue"
    tables="FROM reg r JOIN memList m ON r.memid = m.id"
    where="WHERE (r.price = 0 OR r.paid > 0) AND r.conid BETWEEN ? - 4 AND ? GROUP BY r.conid, label"
[C002]
    name=labels
    select="SELECT DISTINCT label"
    tables="FROM data"
    where=""
[C003]
    name=wide
    select="SELECT l.label, MAX(c1.conid) AS c1conid, IFNULL(SUM(c1.Count),0) AS c1count, IFNULL(AVG(c1.Average), 0) AS c1avg, IFNULL(SUM(c1.Revenue), 0) AS
    c1rev,
MAX(c2.conid) AS c2conid, IFNULL(SUM(c2.Count),0) AS c2count, IFNULL(AVG(c2.Average), 0) AS c2avg, IFNULL(SUM(c2.Revenue), 0) AS c2rev,
MAX(c3.conid) AS c3conid, IFNULL(SUM(c3.Count),0) AS c3count, IFNULL(AVG(c3.Average), 0) AS c3avg, IFNULL(SUM(c3.Revenue), 0) AS c3rev,
MAX(c4.conid) AS c4conid, IFNULL(SUM(c4.Count),0) AS c4count, IFNULL(AVG(c4.Average), 0) AS c4avg, IFNULL(SUM(c4.Revenue), 0) AS c4rev,
MAX(c5.conid) AS c5conid, IFNULL(SUM(c5.Count),0) AS c5count, IFNULL(AVG(c5.Average), 0) AS c5avg, IFNULL(SUM(c5.Revenue), 0) AS c5rev
FROM labels l
LEFT OUTER JOIN data c1 on l.label = c1.label AND c1.conid = ?
LEFT OUTER JOIN data c2 on l.label = c2.label AND c2.conid = ? - 1
LEFT OUTER JOIN data c3 on l.label = c3.label AND c3.conid = ? - 2
LEFT OUTER JOIN data c4 on l.label = c4.label AND c4.conid = ? - 3
LEFT OUTER JOIN data c5 on l.label = c5.label AND c5.conid = ? - 4"
    where="GROUP BY l.label"
    tables=""
[C004]
    name=allrows
    select="SELECT 'Paid' AS Cat, wide.* FROM wide
WHERE c1avg != 0 OR c2avg != 0 OR c3avg != 0 OR c4avg != 0 OR c5avg != 0
UNION
SELECT 'Free' AS Cat, wide.* FROM wide
WHERE c1avg = 0 AND c2avg = 0 AND c3avg = 0 AND c4avg = 0 AND c5avg = 0
ORDER BY Cat DESC, c2rev desc, label"
    where=""
    tables=""
[P001]
    type=prompt
    item=conid
