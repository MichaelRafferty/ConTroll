;; B:O
logoalt=""
;;;;; HR Portal Options
;;; Portal Options
;; N:history
;; R:H,reg_staff
;; H:Enable the membership History menu button
;; H+&nbsp;&nbsp;&nbsp;&nbsp;set to 0 to disable (hide) the button, 1 to enable it (show)
;; D:l:0,1
;; B:O
;;; enable registration history for prior years
; history = 1 = show membership history menu item, 0 = suppress, missing/null = show
history=1
;;; memberbadgencolor: hex string of the color of the membership "badges" on the portal home screen, to override the standard color scheme
;;; Art Show Price Tag Items
;; N:memberbadgecolors
;; R:V,reg_staff
;; P:#000000 fmt
;; H:Override the default membership badge color scheme, and make them all the color specified in this option.
;; D:s7
;; B:O
;       note; standard color scheme has the buttons having a color that describe the membership type, the legend supports this color scheme
;           the override is a single color for all of the badges.  Presence of this line will auto suppress the legend.
;memberbadgecolors="#000000"
;; N:suppresslegend
;; R:H,reg_staff
;; H:Suppress the membership badge color legend
;; H+&nbsp;&nbsp;&nbsp;&nbsp;set to 1 to suppress (hide) the legend, 0 to enable it (show) (Note this is suppress now SHOW)
;; D:l:0,1
;; B:O
;;;; suppresslegend: if memberbasgecolor is not used, missing or 0 will show the legend, 1 will suppress the legend
;suppresslegend=0
;; N:helppage
;; R:V,reg_staff
;; P:Relative path
;; H:File name of the help page (pdf or php) releative to the portal web root
;; H+ (relative to where portal's index.php file is contained)
;; H+ The help menu item is hidden if this entry is missing or the file is not readable
;; D:s256
;; B:O
; helppage = path to the help page relative to the web root of the portal page
; helppage=
;;;;; HR Portal Policy Options
;;; policy flags
;; N:showConPolicy
;; R:H,reg_staff
;; H:Shows the "Click here for the #conname# Policies",
;; H+&nbsp;&nbsp;&nbsp;&nbsp;set to 0 if agree to policy is one of your ConTroll policies or 1 otherwise
;; D:l:0,1
;; B:O
; showConPolicy - shows the "Click here for the #conname# Policies",
;     set to 0 if agree to policy is one of your policies or 1 otherwise
showConPolicy=1
;; N:showVolunteerPolicy
;; R:H,reg_staff
;; H:Shows the "#Conname# is entirely run by volunteers" line in the policy block,
;; H+&nbsp;&nbsp;&nbsp;&nbsp;set to 0 if volunteers is in your interest section, 1 otherwise
;; D:l:0,1
;; B:O
; showVolunteerPolicy - shows the "#Conname# is entirely run by volunteers" line in the policy block,
;      set to 0 if volunteers is in your interest section, 1 otherwise
; showVolunteerPolicy - shows the "#Conname# is entirely run by volunteers" line in the policy block,
;      set to 0 if volunteers is in your interest section, 1 otherwise
showVolunteerPolicy=1

;;;;; ConTroll Back End System
[controll]
;; N:badgelistfilter
;; R:H,reg_admin
;; H:Positioning of the filter block on the reg-admin membership list
;; H+bottom = after list
;; H+top = before list
;; D:l:bottom,top
;; B:O
; badgelistfilter - where to put the filter elements on the badgelist page ("top", "bottom")
badgelistfilter="bottom"
;; N:posRegistrationSort
;; R:H,reg_admin
;; H:How to sort the registration items in Registration
;; H+m.sort_order = Sort order from the memList in Current Convention Setup
;; H+conid, mt.sortorder, m.label = Convention ID, then membership type sort order, then membership label (name)
;; H+conid, m.label = Convention ID, then membership label (name)
;; D:l:m.sort_order,conid/mt.sortorder/m.label,conid/m.label
;; B:R
; posRegistrationSort - where to put the filter elements on the badgelist page ("top", "bottom")
posRegistrationSort="m.sort_order";
;; N:clubname
;; R:H,club
;; P:club name
;; H:Club name for the club section.
;; D:s32
;; B:O
clubname='Club Name'

;;;;; Local Parameters for this Convention
[local]
;;; local parameters for the sendinterests.php send script
;; N:csvto
;; R:H,reg_admin
;; P:email address to receive the overall interest file
;; H:The email address to receive the overall interest file
;; D:e
;; B:O
;   cvsto = what email address to receive the overall VS file
;csvto=
;; N:csvcc
;; R:H,reg_admin
;; P:email address to receive CC of interests
;; H:The email address to receive CC's of all emails sent about interests
;; D:e
;; B:O
;   cvscc = what email address, if any gets CC on all emails sent my sendinterests.php
;csvcc=
